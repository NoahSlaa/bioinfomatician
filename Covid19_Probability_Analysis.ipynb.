        "from matplotlib.patches import bbox_artist\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "df=pd.read_csv('country_wise_latest.csv')\n",
        "east_africa=[\"Tanzania\",\"Kenya\",\"Uganda\",\"Rwanda\",\"Buruni\",\"South Sudan\",\"Zimbabwe\"]\n",
        "rough=df[df[\"Country/Region\"].isin(east_africa)].reset_index(drop=True).sort_values(by='Country/Region')\n",
        "droped=[\"New cases\",\"New cases\"\t,\"New deaths\"\t,\"New recovered\"\t,\"Deaths / 100 Cases\"\t,\"Recovered / 100 Cases\",\t\"Deaths / 100 Recovered\",\"Confirmed last week\",\t\"1 week change\"\t,\"1 week % increase\",\t\"WHO Region\"]\n",
        "smooth=rough.drop(columns=droped)\n",
        "display(smooth.head())\n",
        "\n",
        "total=smooth['Confirmed'].sum()\n",
        "smooth[\"probability\"]=smooth['Confirmed']/total\n",
        "sns.set_theme(style=\"whitegrid\")\n",
        "plt.figure(figsize=(10,6))\n",
        "display(smooth[[\"Country/Region\",\"Confirmed\",\"probability\",\"Deaths\",\"Recovered\",\"Active\"]])\n",
        "ax=sns.barplot(x=\"Country/Region\",y=\"probability\",data=smooth,palette=\"viridis\")\n",
        "for p in ax.patches:\n",
        "  ax.annotate(f\"{p.get_height():.2f}\",(p.get_x()+p.get_width()/2.,p.get_height()),ha=\"center\",va=\"center\",xytext=(0,10),weight=\"bold\",fontsize=11,textcoords=\"offset points\")\n",
        "plt.xticks(rotation=60,weight=\"bold\")\n",
        "plt.ylim(0,1)\n",
        "plt.yticks(weight=\"bold\")\n",
        "plt.title(\"PROBABILITY DISTRIBUTION OF CONFIRMED CASES\",weight=\"bold\")\n",
        "plt.xlabel(\"COUNTRY\",weight=\"bold\")\n",
        "plt.ylabel(\"PROBABILITY\",weight=\"bold\")\n",
        "plt.savefig(\"probability.png\",dpi=300,bbox_inches=\"tight\")\n",
        "plt.show()\n",
        "files.download(\"probability\")\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n"

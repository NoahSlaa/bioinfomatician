        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "df=pd.read_csv(\"Dataset.csv\")\n",
        "data=df[df['Cell Line'].str.startswith(\"MDA\",na=False)]\n",
        "\n",
        "data[\"-log10_p\"]=-np.log10(data[\"P.Value\"])\n",
        "display(data)\n",
        "\n",
        "data[\"Status\"]=\"No change\"\n",
        "data.loc[(data['logFC']> 1)& (data['-log10_p']>1.3),\"Status\"]=\"Upregulated\"\n",
        "data.loc[(data['logFC']< -1)& (data['-log10_p']>1.3),\"Status\"]=\"Downregulated\"\n",
        "sns.set_style(\"white\")\n",
        "plt.figure(figsize=(10,7))\n",
        "sns.scatterplot(data=data,x=\"logFC\",y=\"-log10_p\",hue=\"Status\",palette={\"Upregulated\":\"#eb4c34\",\"Downregulated\":\"#636363\",\"No change\":\"#34ebc6\"},\n",
        "                s=6,alpha=0.9,rasterized=True)\n",
        "plt.axhline(y=1.3,color=\"black\",linestyle=\"--\",alpha=0.6,label=\"P-value=0.05\")\n",
        "plt.axvline(x=1,color=\"black\",linestyle=\"--\",alpha=0.6)\n",
        "plt.axvline(x=-1,color=\"black\",linestyle=\"--\",alpha=0.6)\n",
        "\n",
        "plt.title(\"Volcano Plot :Analysis of MDA(Genes 40k+)\",fontsize=12,fontweight='bold')\n",
        "plt.xlabel(\"log2 fold change(log FC)\",fontweight='bold')\n",
        "plt.ylabel(\"-log10 P-value(-log)\",fontsize=12)\n",
        "plt.legend(title=\"Gene status\")\n",
        "plt.grid(True,alpha=0.1)\n",
        "\n",
        "plt.show()\n"
      ],
